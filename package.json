{
  "name": "island-designer",
  "version": "0.1.0",
  "description": "Pokopia island planning workbench",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment jsdom",
    "build": "vite build",
    "secret-scan": "node scripts/secret-scan.mjs",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run build && pnpm run secret-scan"
  },
  "keywords": [
    "pokopia",
    "island",
    "planner"
  ],
  "author": "Pokopia",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
